APP_NAME="ATLAS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=atlas_db
DB_USERNAME=postgres
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@atlas.prattica.ai"
MAIL_FROM_NAME="ATLAS"

# Claude API
CLAUDE_API_KEY=sk-ant-
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2000

# Pagar.me
PAGARME_API_KEY=sk_
PAGARME_PUBLIC_KEY=pk_
PAGARME_WEBHOOK_SECRET=
PAGARME_ENVIRONMENT=sandbox

# Planos Pagar.me (IDs criados no dashboard)
PAGARME_PLAN_SOLO=
PAGARME_PLAN_PRO=
PAGARME_PLAN_OFFICE=

# WeasyPrint
WEASYPRINT_PATH=/usr/local/bin/weasyprint

# SINAPI
SINAPI_CACHE_DAYS=30
SINAPI_DEFAULT_BDI=25

# Storage
PDF_SIGNED_URL_MINUTES=15
